{
  "name": "Yii2 PHP & MySQL",
  "image": "mcr.microsoft.com/devcontainers/php:1-8.2-bullseye",
  "features": {
    "ghcr.io/devcontainers/features/mysql:1": {
      "databaseName": "db_pubman",
      "databaseUser": "pubman_app",
      "databasePassword": "pubmanapp"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": ["bmewburn.vscode-inteliphense-client", "yiisoft.yii2-vscode-extension"]
    }
  },
  "forwardPorts": [8080, 3306],
  "postCreateCommand": "mysql -u root < schema.sql && composer install"
}
